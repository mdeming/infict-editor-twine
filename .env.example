# =============================================================================
# Twine fork: where to set these
# =============================================================================
# Copy to `.env` or `.env.local` in the **twinejs** repo root (same folder as
# package.json). Vite loads `VITE_*` at dev/build time; they are inlined into
# the client bundle via vite.config.mts (loadEnv + define).

# -----------------------------------------------------------------------------
# Local Controller + local Snowcone (typical dev)
# -----------------------------------------------------------------------------
# 1. Run Controller (e.g. port 5000) so Twine can load Snowcone format.js from it:
#    VITE_SNOWCONE_FORMAT_BASE_URL=http://localhost:5000
#    (builds URL: {base}/twinejs/story-formats/snowcone-1.0.26/format.js)
#    Or full URL:
#    VITE_SNOWCONE_FORMAT_URL=http://localhost:5000/twinejs/story-formats/snowcone-1.0.26/format.js
# 2. Point the lazy passage editor at your Snowcone checkout (not npm):
#    VITE_DIALOG_FORMS_ROOT=../Snowcone
#    Path is relative to the twinejs repo root; must contain package.json / dialog-forms.
# 3. Rebuild Snowcone format and copy into Controller's static tree when you change
#    editorExtensions / hydrate (so Controller serves the format.js you expect).

# Fork extended build (Snowcone default, remote embed, extended passage editor). Set to "false" for upstream-core-style builds.
# VITE_TWINE_FORK_EXTENDED=true
# Legacy alias (same meaning) — still read by isForkExtendedBuild():
# VITE_INFICT_TWINE=true

# Default Snowcone story format `format.js` (JSONP). Overrides bundled Controller production URL.
# VITE_SNOWCONE_FORMAT_URL=https://localhost:5000/twinejs/story-formats/snowcone-1.0.26/format.js
# Or set only the site origin:
# VITE_SNOWCONE_FORMAT_BASE_URL=http://localhost:5000

# Point Twine at a local Snowcone checkout instead of npm (folder containing package.json / dialog-forms-dist).
# VITE_DIALOG_FORMS_ROOT=../Snowcone

# Optional JSON array of extra builtin formats: [{"name":"","version":"","url":""}, ...]
# VITE_TWINE_EXTRA_BUILTINS=[]

# Optional JSON object mapping logical module id → relative path (Vite resolve.alias)
# VITE_TWINE_MODULE_ALIASES={}

# Optional remote embed query param names (defaults: apiEndpoint, storyId, authToken, replaceExisting)
# VITE_TWINE_REMOTE_QUERY_KEYS={}

# Optional story POST/GET path template (defaults to {apiBase}/stories/{storyId})
# VITE_TWINE_REMOTE_STORY_PATH_TEMPLATE={apiBase}/stories/{storyId}

# -----------------------------------------------------------------------------
# Default story format for new stories (optional; see src/config/format-defaults.ts)
# -----------------------------------------------------------------------------
# VITE_DEFAULT_FORMAT_NAME=Snowcone
# VITE_DEFAULT_FORMAT_VERSION=1.0.26
# Legacy CRA-style names also supported:
# REACT_APP_DEFAULT_FORMAT_NAME=...
# REACT_APP_DEFAULT_FORMAT_VERSION=...
